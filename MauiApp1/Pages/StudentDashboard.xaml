<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Pages.StudentDashboard"
             Title="Home">
    <ScrollView 
        Padding="15">
        <Grid
            RowDefinitions="Auto, Auto, Auto, Auto, *"
            ColumnDefinitions="*,*,*,*"
            RowSpacing="13"
            ColumnSpacing="3">

            <VerticalStackLayout
                Grid.Row="0"
                VerticalOptions="Start"
                Padding="16"
                Spacing="5"
                Grid.Column="0"
                Grid.ColumnSpan="4">

                <Label
                    Text="Greetings, User"
                    FontSize="Large"
                    FontAttributes="Bold" />
                <Label
                    Text="Welcome to your dashboard. Ready to plan your session?"
                    FontSize="Small" />
            </VerticalStackLayout>
            
            <!-- Booking Slot -->

                <Button
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,0,4,0"
                Style="{StaticResource Board}"
                Text="Book a Slot"
                TextColor="Black"
                Clicked="OnBookSlotClicked" 
                HorizontalOptions="Fill">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F5A623" Offset="0.0" />
                        <GradientStop Color="#F7C948" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <!-- Manage Sessions -->

            <Button
                Grid.Row="1"
                Grid.Column="2"
                Grid.ColumnSpan="2"
                Margin="4,0,0,0"
                Style="{StaticResource SecondBoard}"
                Text="My Recent Sessions"
                Clicked="OnManageSlotsClicked"
                HorizontalOptions="Fill"
                TextColor="White">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A56DB" Offset="0.0" />
                        <GradientStop Color="#3B82F6" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
            
        </Grid>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.MainPage">

  
        <ScrollView>
            <VerticalStackLayout Padding="32" Spacing="0" VerticalOptions="Center">

                <!-- Logo / Title -->
                <Label
                Text="Log-in"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="#1A56DB"
                HorizontalOptions="Center"
                Margin="0,60,0,4" />

                <Label
                Text="Sign in to your account"
                FontSize="14"
                TextColor="Gray"
                HorizontalOptions="Center"
                Margin="0,0,0,40" />

                <!-- Email -->
                <Label Text="Email" FontSize="13" TextColor="#333" Margin="0,0,0,4" />
                <Border Stroke="#DDDDDD" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                    <Entry
                    x:Name="EmailEntry"
                    Placeholder="Enter your email"
                    Keyboard="Email"
                    Margin="12,8" />
                </Border>

                <!-- Password -->
                <Label Text="Password" FontSize="13" TextColor="#333" Margin="0,16,0,4" />
                <Border Stroke="#DDDDDD" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                    <Entry
                    x:Name="PasswordEntry"
                    Placeholder="Enter your password"
                    IsPassword="True"
                    Margin="12,8" />
                </Border>

                <!-- Login Button -->
                <Button
                Text="Log In"
                Clicked="OnLoginClicked"
                CornerRadius="8"
                Margin="0,28,0,0"
                HeightRequest="50"
                FontAttributes="Bold"
                FontSize="16">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A56DB" Offset="0.0" />
                            <GradientStop Color="#3B82F6" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <!-- Error Message -->
                <Label
                x:Name="ErrorLabel"
                Text=""
                TextColor="Red"
                FontSize="13"
                HorizontalOptions="Center"
                Margin="0,12,0,0"
                IsVisible="False" />

            </VerticalStackLayout>
        </ScrollView>

</ContentPage>
